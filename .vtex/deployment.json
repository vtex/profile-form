[
  {
    "name": "profile-form",
    "referenceId": "G5H5RQFQ",
    "description": "CI/CD and TechDocs pipeline for profile-form",
    "source": "https://github.com/vtex/profile-form.git",
    "script": {
      "deploy": ".vtex/deploy.yml",
      "ci": ".vtex/ci.yml"
    },
    "build": {
      "provider": "dkcicd",
      "pipelines": [
        {
          "name": "node-ci-v2",
          "parameters": {
            "nodeCommands": ["lint", "build", "test:coverage"]
          },
          "when": [
            {
              "event": "push",
              "source": "branch"
            }
          ]
        },
        {
          "name": "techdocs-v1",
          "parameters": {
            "entityReference": "default/component/profile-form"
          },
          "when": [
            {
              "event": "push",
              "source": "branch",
              "regex": "main",
              "path": [
                "docs/**",
                ".vtex/deployment.yaml",
                ".vtex/deployment.json",
                "README.md"
              ]
            }
          ]
        }
      ]
    }
  }
]
